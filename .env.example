# .env.example

# === LLM Provider 切換開關 ===
# 可選值: "openai" | "google"，決定系統使用哪家 LLM API
LLM_PROVIDER="google"

# (選填) 自訂模型名稱，不填則使用預設值
# OpenAI 預設: gpt-4o / Google 預設: gemini/gemini-2.0-flash
# LLM_MODEL_NAME="gemini/gemini-2.0-flash"

# OpenAI 設定 (當 LLM_PROVIDER="openai" 時使用)
OPENAI_API_KEY="your_openai_api_key_here"

# Google Gemini 設定 (當 LLM_PROVIDER="google" 時使用)
GEMINI_API_KEY="your_gemini_api_key_here"

# Supabase Configuration
# 請替換為您的 Supabase 專案 URL
SUPABASE_URL="https://your-project-ref.supabase.co"
# 請替換為您的 Supabase anon key (公開可讀取金鑰)
SUPABASE_KEY="your_supabase_anon_key_here"
# 可編輯的 Supabase key
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_key_here"

# Qdrant 設定 (如果是 Cloud 版填 URL/API Key，如果是 Local Docker 填 localhost)
QDRANT_URL="your_qdrant_url" 
QDRANT_API_KEY="your_api_key"

# Qdrant 資料庫
QDRANT_JOB_COLLECTION_NAME="job_資料庫名稱" 
QDRANT_RESUMES_COLLECTION_NAME="resume_資料庫名稱"
QDRANT_RESUMES_OPTIMIZATION_COLLECTION_NAME="optimized_resume_資料庫名稱"

